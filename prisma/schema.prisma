generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// Untuk Profil Perangkat Desa dan BPD
model PerangkatDesa {
  id        Int      @id @default(autoincrement())
  nama      String
  jabatan   String
  tipe      String   @default("Perangkat Desa") // "Perangkat Desa" atau "BPD"
  fotoUrl   String?  // URL gambar di-upload misal ke Vercel Blob/Cloudinary
}

// Untuk Etalase UMKM / Produk Kreatif
model ProdukUMKM {
  id           Int      @id @default(autoincrement())
  namaProduk   String
  deskripsi    String   @db.Text
  namaPemilik  String
  kontakWa     String
  fotoUrl      String?
  kategori     String   @default("Lainnya")
  kisaranHarga String   @default("Hubungi Kontak")
}

// Untuk Berita / Kegiatan / Pengumuman
model Artikel {
  id        Int           @id @default(autoincrement())
  judul     String
  kategori  String        // Bisa diisi "Berita", "Pengumuman", atau "Kegiatan"
  konten    String        @db.Text
  fotoUrl   String?
  isSorotan Boolean       @default(false)
  createdAt DateTime      @default(now())
  bloks     ArtikelBlok[]
}

// Blok konten untuk artikel (teks atau gambar, seperti cell di Google Colab)
model ArtikelBlok {
  id        Int      @id @default(autoincrement())
  artikelId Int
  artikel   Artikel  @relation(fields: [artikelId], references: [id], onDelete: Cascade)
  tipe      String   // "teks" atau "gambar"
  konten    String   @db.Text  // isi teks atau URL gambar
  caption   String?  // caption opsional (untuk blok gambar)
  urutan    Int      // urutan tampil (0, 1, 2, ...)
}

// Untuk Statistik Pengunjung
model Visit {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
}

// Untuk Data Demografi Penduduk
model StatistikPenduduk {
  id       Int    @id @default(autoincrement())
  kategori String // "Agama", "Jenis Kelamin", "Pekerjaan", "Pendidikan", dll.
  label    String // "Islam", "Laki-laki", "Petani", "SD", dll.
  jumlah   Int    @default(0)

  @@unique([kategori, label])
}

// Untuk Pusat Layanan & Informasi Publik Desa
model LayananPublik {
  id           String   @id @default(uuid())
  kategori     String   // "Pengaduan / Informasi Publik" atau "Permohonan Surat"
  namaPemohon  String
  kontak       String   // Nomor WhatsApp
  perihal      String   @db.Text
  tanggapan    String?  @db.Text // Jawaban dari admin desa
  status       String   @default("Belum Direspon")
  createdAt    DateTime @default(now())
}

// Untuk Arsip Digital Desa
model ArsipDigital {
  id           Int      @id @default(autoincrement())
  nomor        String
  tahun        Int
  perihal      String
  isiDokumen   String   @db.Text
  kategori     String   @default("Lainnya")
  lokasiSimpan String   @db.Text
  jumlah       Int
  filePdfUrl   String?
  createdAt    DateTime @default(now())
}

// Tabel dummy untuk keep-alive ping (mencegah Supabase free tier pause)
model KeepAlive {
  id       Int      @id @default(1)
  pingedAt DateTime @default(now()) @map("pinged_at")

  @@map("keep_alive")
}

// Untuk Akun Admin & Superadmin
model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  salt         String
  role         String   @default("admin") // "admin" atau "superadmin"
  namaLengkap  String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

// Untuk Pengetahuan AI Chatbot
model ChatbotKnowledge {
  id        Int      @id @default(autoincrement())
  judul     String
  isi       String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Untuk Peraturan Desa (JDIH)
model PeraturanDesa {
  id           String   @id @default(cuid())
  judul        String
  nomor        String
  tahun        String
  kategori     String   // "Peraturan Desa", "Keputusan Kepala Desa", "Peraturan Kepala Desa"
  isiDokumen   String   @db.Text
  filePdfUrl   String?
  lokasiSimpan String
  jumlah       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}